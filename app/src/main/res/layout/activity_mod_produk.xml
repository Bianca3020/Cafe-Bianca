<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:backgroundTint="@color/surface_variant"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/surface_variant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:backgroundTint="@color/surface_variant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:layout_marginEnd="16dp"
                app:tint="@color/icon_color"/>

            <TextView
                android:id="@+id/tvTitleHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tambah_produk"
                android:textSize="24sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <ImageView
                    android:id="@+id/imgProduk"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_camera"
                    app:tint="?attr/colorOnSurface"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/link_foto"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etLinkFoto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_link_url"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_nama_produk_form"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_nama_produk_form"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_harga_produk_form"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etHarga"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_harga_produk_form"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kategori"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spKategori"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_cabang"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spCabang"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_stok_produk"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etStok"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_stok_produk"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="8dp"/>

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/cbUnlimited"
                android:text="@string/label_tanpa_batas"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="20dp"/>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/simpan"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/button"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_on_button"/>

                <Button
                    android:id="@+id/btnHapus"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/button_hapus"
                    android:text="@string/hapus_produk"
                    android:textColor="@color/text_on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone"
                    android:elevation="2dp" />
        </LinearLayout>
    </ScrollView>

</androidx.cardview.widget.CardView>