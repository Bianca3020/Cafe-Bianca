<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <ScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_back"
                    android:layout_marginEnd="16dp"
                    app:tint="?attr/colorOnSurface"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tambah Produk"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <!-- FOTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_camera"
                        app:tint="?attr/colorOnSurface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tambah Foto"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NAMA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Nama Produk"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Masukkan nama produk"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <!-- HARGA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Harga"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etHarga"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Masukkan harga"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <!-- KATEGORI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Kategori"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spKategori"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"/>

            <!-- CABANG -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cabang"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spCabang"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"/>

            <!-- STOK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Stok"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etStok"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Jumlah stok"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="8dp"/>

            <!-- CHECKBOX -->
            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:id="@+id/cbUnlimited"
                android:text="Stok Tak Terbatas"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="20dp"/>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Simpan"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:background="?attr/colorPrimary"/>

        </LinearLayout>
    </ScrollView>

</androidx.cardview.widget.CardView>