<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface_variant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgPegawai"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_staff"
            android:scaleType="centerInside"
            app:tint="@color/icon_color"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pegawai"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/tvRolePegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kasir"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvEmailPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="email@example.com"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/tvNoHpPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="08xxxxxxxxxx"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnAtur"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/mengatur"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/button"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_on_button"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>